{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rutea.local/schemas/native-response.schema.json",
  "title": "Respuesta Native Messaging de Rutea",
  "description": "Respuesta estructurada del host a un mensaje de la extensión. Conserva la correlación con el mensaje original y expone un resultado o un error de la taxonomía acordada en 003_ARQUITECTURA_Y_LIMITES.",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocolVersion", "ok", "correlationId", "timestamp"],
  "properties": {
    "protocolVersion": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "ok": {
      "type": "boolean"
    },
    "payload": {
      "type": "object"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "enum": [
            "VALIDATION_ERROR",
            "UNSUPPORTED_PROTOCOL",
            "UNSUPPORTED_CAPABILITY",
            "DOMAIN_NOT_ALLOWED",
            "TARGET_NOT_FOUND",
            "AMBIGUOUS_TARGET",
            "PRECONDITION_FAILED",
            "POSTCONDITION_FAILED",
            "CONFIRMATION_REQUIRED",
            "USER_CANCELLED",
            "TIMEOUT",
            "SECRET_UNAVAILABLE",
            "AI_PROVIDER_ERROR",
            "PERSISTENCE_ERROR",
            "INTERNAL_ERROR"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}
