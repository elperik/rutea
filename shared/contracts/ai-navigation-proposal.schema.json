{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rutea.local/schemas/contracts/ai-navigation-proposal.schema.json",
  "title": "Propuesta de navegación asistida",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "proposalId",
    "requestId",
    "status",
    "strategyUsed",
    "actions",
    "explanation"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "proposalId": { "type": "string", "format": "uuid" },
    "requestId": { "type": "string", "format": "uuid" },
    "status": {
      "enum": ["actions_proposed", "completed", "needs_user", "cannot_proceed"]
    },
    "strategyUsed": { "enum": ["structured", "computer"] },
    "actions": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/$defs/proposedAction" }
    },
    "explanation": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "stopReason": { "type": "string", "maxLength": 1000 }
  },
  "$defs": {
    "proposedAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "grounding",
        "action",
        "risk",
        "requiresConfirmation",
        "rationale"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "grounding": { "enum": ["semantic", "visual"] },
        "action": {
          "enum": [
            "navigate",
            "click",
            "fill",
            "select",
            "check",
            "upload",
            "download",
            "wait",
            "assert",
            "double_click",
            "scroll",
            "type",
            "keypress",
            "drag",
            "move",
            "screenshot"
          ]
        },
        "controlId": { "type": "string", "pattern": "^c[0-9]+$" },
        "actionId": { "type": "string", "pattern": "^a[0-9]+$" },
        "value": {},
        "computer": { "$ref": "#/$defs/computerAction" },
        "risk": { "enum": ["low", "medium", "high", "irreversible"] },
        "requiresConfirmation": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "postcondition": { "$ref": "#/$defs/navigationPostcondition" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "grounding": { "const": "semantic" } },
            "required": ["grounding"]
          },
          "then": {
            "anyOf": [{ "required": ["controlId"] }, { "required": ["actionId"] }]
          }
        },
        {
          "if": {
            "properties": { "grounding": { "const": "visual" } },
            "required": ["grounding"]
          },
          "then": { "required": ["computer"] }
        }
      ]
    },
    "computerAction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number", "minimum": 0 },
        "y": { "type": "number", "minimum": 0 },
        "button": { "enum": ["left", "middle", "right"] },
        "scrollX": { "type": "number" },
        "scrollY": { "type": "number" },
        "text": { "type": "string", "maxLength": 8000 },
        "keys": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "maxLength": 80 }
        },
        "startX": { "type": "number", "minimum": 0 },
        "startY": { "type": "number", "minimum": 0 },
        "endX": { "type": "number", "minimum": 0 },
        "endY": { "type": "number", "minimum": 0 }
      }
    },
    "navigationPostcondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": [
            "urlMatches",
            "elementVisible",
            "elementHidden",
            "textVisible",
            "valueEquals",
            "screenChanged"
          ]
        },
        "value": {},
        "controlId": { "type": "string", "pattern": "^c[0-9]+$" }
      }
    }
  }
}
